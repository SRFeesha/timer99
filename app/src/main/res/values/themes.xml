<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Dark, no-action-bar base. The explicit color items prevent a white
        window flash before Compose renders its first frame.
    -->
    <style name="Theme.Timer99" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
    </style>
</resources>
